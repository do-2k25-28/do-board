FROM rust:1.94-slim
RUN apt-get update \
    && apt-get install -y --no-install-recommends pkg-config libssl-dev \
    && rm -rf /var/lib/apt/lists/*
RUN cargo install cargo-watch --locked
WORKDIR /app
CMD ["cargo", "watch", \
     "-w", "backend/src", \
     "-w", "backend/Cargo.toml", \
     "-w", "shared/src", \
     "-w", "shared/Cargo.toml", \
     "-x", "run -p backend"]
